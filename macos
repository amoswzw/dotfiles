#!/usr/bin/env bash

set -euo pipefail

# macOS Tahoe 26.x settings
# Updated: 2026-04-30

if [[ "$(sw_vers -productVersion | cut -d. -f1)" != "26" ]]; then
  echo "This script is intended for macOS Tahoe 26.x only."
  exit 1
fi

# Close System Settings before applying preference changes.
osascript -e 'tell application "System Settings" to quit'

# Request administrator privileges.
sudo -v

# Keep the sudo timestamp alive while the script runs.
while true; do
  sudo -n true
  sleep 60
  kill -0 "$$" || exit
done 2>/dev/null &

###############################################################################
# Current machine settings
###############################################################################

# Enable dark mode.
osascript -e 'tell application "System Events" to tell appearance preferences to set dark mode to true'

# Set the accent color to pink.
defaults write NSGlobalDomain AppleAccentColor -int 6

# Set the highlight color to pink.
defaults write NSGlobalDomain AppleHighlightColor -string "1.000000 0.749020 0.823529 Pink"

# Enable reduced transparency.
defaults write com.apple.universalaccess reduceTransparency -bool true

# Enable reduced motion.
defaults write com.apple.universalaccess reduceMotion -bool true

# Set full keyboard access to 2.
defaults write NSGlobalDomain AppleKeyboardUIMode -int 2

# Set key repeat to 2.
defaults write NSGlobalDomain KeyRepeat -int 2

# Set initial key repeat to 15.
defaults write NSGlobalDomain InitialKeyRepeat -int 15

# Set preferred languages to en-US, then zh-Hans-US.
defaults write NSGlobalDomain AppleLanguages -array "en-US" "zh-Hans-US"

# Set the locale to en_US.
defaults write NSGlobalDomain AppleLocale -string "en_US"

# Set the timezone to Asia/Shanghai.
sudo systemsetup -settimezone "Asia/Shanghai" > /dev/null

# Set display sleep to 2 minutes on battery.
sudo pmset -b displaysleep 2

# Set display sleep to 10 minutes on AC power.
sudo pmset -c displaysleep 10

# Set system sleep to 1 minute on battery.
sudo pmset -b sleep 1

# Set system sleep to 1 minute on AC power.
sudo pmset -c sleep 1

# Enable standby mode.
sudo pmset -a standby 1

# Enable Power Nap.
sudo pmset -a powernap 1

# Disable Wake for network access on battery.
sudo pmset -b womp 0

# Enable Wake for network access on AC power.
sudo pmset -c womp 1

# Enable TCP keepalive during sleep.
sudo pmset -a tcpkeepalive 1

# Enable tap to click.
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true

# Enable tap behavior for the current host.
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# Enable secondary click.
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadRightClick -bool true

# Set secondary click corner behavior to 0.
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadCornerSecondaryClick -int 0

# Enable current-host secondary click support.
defaults -currentHost write NSGlobalDomain com.apple.trackpad.enableSecondaryClick -bool true

# Enable scroll-wheel zoom toggle.
defaults write com.apple.universalaccess closeViewScrollWheelToggle -bool true

# Set Control as the zoom modifier.
defaults write com.apple.universalaccess HIDScrollZoomModifierMask -int 262144

# Open new Finder windows to Recents.
defaults write com.apple.finder NewWindowTarget -string "PfAF"

# Show external drives on the desktop.
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool true

# Hide internal drives on the desktop.
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false

# Show removable media on the desktop.
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool true

# Use icon view in Finder by default.
defaults write com.apple.finder FXPreferredViewStyle -string "icnv"

# Set the Dock icon size to 67.
defaults write com.apple.dock tilesize -int 67

# Enable Dock auto-hide.
defaults write com.apple.dock autohide -bool true

# Disable Dock launch animations.
defaults write com.apple.dock launchanim -bool false

# Disable automatic Space reordering.
defaults write com.apple.dock mru-spaces -bool false

# Hide recent apps in the Dock.
defaults write com.apple.dock show-recents -bool false

# Set the top-left hot corner to Application Windows.
defaults write com.apple.dock wvous-tl-corner -int 3
defaults write com.apple.dock wvous-tl-modifier -int 0

# Set the top-right hot corner to Desktop.
defaults write com.apple.dock wvous-tr-corner -int 4
defaults write com.apple.dock wvous-tr-modifier -int 0

# Set the bottom-left hot corner to Lock Screen.
defaults write com.apple.dock wvous-bl-corner -int 13
defaults write com.apple.dock wvous-bl-modifier -int 0

# Set the bottom-right hot corner to Mission Control.
defaults write com.apple.dock wvous-br-corner -int 2
defaults write com.apple.dock wvous-br-modifier -int 0

# Open Activity Monitor to the main window.
defaults write com.apple.ActivityMonitor OpenMainWindow -bool true

# Set Activity Monitor category to 102.
defaults write com.apple.ActivityMonitor ShowCategory -int 102

